# ---------- Global LLM defaults ----------
# Supported: ollama | openai
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5-coder:7b-instruct
LLM_TEMP=0.2

# For Ollama/OpenAI-compatible local endpoints
OLLAMA_BASE_URL=http://10.2.104.81:11434/v1

# For OpenAI provider (replace with real key when using openai)
OPENAI_API_KEY=replace-with-real-openai-key

# ---------- Optional per-service overrides ----------
# GC service
GC_LLM_PROVIDER=ollama
GC_LLM_MODEL=qwen2.5-coder:7b-instruct
GC_LLM_TEMP=0.2
GC_OLLAMA_BASE_URL=http://10.2.104.81:11434/v1
GC_OPENAI_API_KEY=replace-with-real-openai-key

# DB2Z service
DB2Z_LLM_PROVIDER=ollama
DB2Z_LLM_MODEL=qwen2.5-coder:7b-instruct
DB2Z_LLM_TEMP=0.2
DB2Z_OLLAMA_BASE_URL=http://10.2.104.81:11434/v1
DB2Z_OPENAI_API_KEY=replace-with-real-openai-key

# Thread dump service
TD_LLM_PROVIDER=ollama
TD_LLM_MODEL=qwen2.5-coder:7b-instruct
TD_LLM_TEMP=0.2
TD_OLLAMA_BASE_URL=http://10.2.104.81:11434/v1
TD_OPENAI_API_KEY=replace-with-real-openai-key

# ---------- TDA runtime ----------
TDA_JAR_PATH=/opt/tda/tda.jar
TDA_JAVA_BIN=java
TDA_MCP_TIMEOUT_SEC=30
TDA_TMP_DIR=/tmp/tda_inputs

# ---------- Thread dump capture ----------
CAPTURE_OUT_DIR=/var/log/threaddumps
CAPTURE_HTTP_TIMEOUT_SEC=10
